    USER ||--o{ ISSUE : "作成する"
    REPOSITORY ||--o{ PULL_REQUEST : "持つ"
    USER ||--o{ PULL_REQUEST : "作成する"
    PULL_REQUEST ||--o{ PR_REVIEW : "レビューされる"
    USER ||--o{ PR_REVIEW : "レビューする"
    USER ||--o{ COMMENT : "投稿する"
    ISSUE ||--o{ COMMENT : "コメントされる"
    PULL_REQUEST ||--o{ COMMENT : "コメントされる"
    REPOSITORY ||--o{ LABEL : "定義する"
    ISSUE ||--o{ ISSUE_LABEL : "ラベル付け"
    LABEL ||--o{ ISSUE_LABEL : "付与される"
    REPOSITORY ||--o{ MILESTONE : "持つ"
    MILESTONE ||--o{ ISSUE : "含む"
    MILESTONE ||--o{ PULL_REQUEST : "含む"
    USER ||--o{ STAR : "スターする"
    REPOSITORY ||--o{ STAR : "スターされる"
    USER ||--o{ WATCH : "ウォッチする"
    REPOSITORY ||--o{ WATCH : "ウォッチされる"
    REPOSITORY ||--o{ RELEASE : "リリースする"
    USER ||--o{ RELEASE : "作成する"
    REPOSITORY ||--o{ ACTIONS_WORKFLOW : "定義する"
