{
  "name": "mermaid-er-viewer",
  "version": "1.0.7",
  "description": "Mermaid ER Diagram Viewer with draggable entities and sidecar layout files",
  "type": "module",
  "bin": {
    "mermaid-er-viewer": "dist/server/index.js",
    "mermaid-er-viewer-mcp": "dist/server/mcp-server.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prepare": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs && node dist/server/index.js",
    "start": "node dist/server/index.js",
    "mcp": "node dist/server/mcp-server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chokidar": "^4.0.0",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0",
    "supertest": "^7.2.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
